// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid())
  email      String   @unique
  phone      String?  @unique
  password   String
  role       AuthRole @default(USER)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  filters            Filter[]
  contacts           Contact[]
  outreach_messages  OutreachMessage[]
  outreach_sequences OutreachSequence[]
  interactions       Interaction[]

  @@index([email])
  @@index([phone])
  @@index([uuid])
  @@map("users")
}

model Filter {
  id              Int        @id @default(autoincrement())
  uuid            String     @unique @default(uuid())
  user_uuid       String
  name            String
  source_type     SourceType
  query_config    Json
  enabled         Boolean    @default(true)
  cron_schedule   String?
  channels        Channel[]  @default([EMAIL])
  ai_instructions String?
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  user      User        @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  raw_leads RawLead[]
  contacts  Contact[]
  jobs      FilterJob[]

  @@index([user_uuid])
}

model RawLead {
  id           Int        @id @default(autoincrement())
  uuid         String     @unique @default(uuid())
  filter_uuid  String
  source_type  SourceType
  raw_data     Json
  processed_at DateTime?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  filter Filter @relation(fields: [filter_uuid], references: [uuid], onDelete: Cascade)
  lead   Lead?

  @@index([filter_uuid])
}

// Lead is the generic, public, app-wide record of a person/business.
// It has no owner. Per-user state (status, score, notes) lives on Contact;
// AI-drafted outreach lives on OutreachMessage (one per filter.channel).
// Each Lead is created from a RawLead (`raw_lead_uuid`), which is the audit
// record of what the scraper returned.
model Lead {
  id              Int        @id @default(autoincrement())
  uuid            String     @unique @default(uuid())
  raw_lead_uuid   String?    @unique
  name            String?
  email           String?
  phone           String?
  company         String?
  website         String?
  linkedin_url    String?
  title           String?
  location        String?
  industry        String?
  description     String?
  source_type     SourceType
  raw_data        Json?
  enrichment_data Json?
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  raw_lead RawLead?  @relation(fields: [raw_lead_uuid], references: [uuid], onDelete: SetNull)
  contacts Contact[]

  @@index([email])
  @@index([linkedin_url])
}

// Contact = the user's connection to a Lead. Owns per-user state:
// status, AI score, notes. AI-drafted outreach is stored on OutreachMessage
// (one per filter.channel), not on Contact.
model Contact {
  id          Int        @id @default(autoincrement())
  uuid        String     @unique @default(uuid())
  user_uuid   String
  lead_uuid   String
  filter_uuid String?
  status      LeadStatus @default(NEW)
  score       Int?
  notes       String?
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  user              User              @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  lead              Lead              @relation(fields: [lead_uuid], references: [uuid], onDelete: Cascade)
  filter            Filter?           @relation(fields: [filter_uuid], references: [uuid], onDelete: SetNull)
  tags              ContactTag[]
  interactions      Interaction[]
  outreach_messages OutreachMessage[]

  @@unique([user_uuid, lead_uuid])
  @@index([user_uuid])
  @@index([status])
  @@index([lead_uuid])
}

model ContactTag {
  id           Int      @id @default(autoincrement())
  contact_uuid String
  tag          String
  created_at   DateTime @default(now())

  contact Contact @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)

  @@unique([contact_uuid, tag])
  @@index([contact_uuid])
}

model Interaction {
  id           Int             @id @default(autoincrement())
  uuid         String          @unique @default(uuid())
  contact_uuid String
  user_uuid    String
  type         InteractionType
  content      String?
  metadata     Json?
  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt

  contact Contact @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)
  user    User    @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)

  @@index([contact_uuid])
  @@index([user_uuid])
}

model OutreachMessage {
  id           Int       @id @default(autoincrement())
  uuid         String    @unique @default(uuid())
  user_uuid    String
  contact_uuid String
  channel      Channel
  subject      String?
  content      String
  status       MsgStatus @default(PENDING)
  scheduled_at DateTime?
  sent_at      DateTime?
  metadata     Json?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  user    User    @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  contact Contact @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)

  @@index([user_uuid])
  @@index([contact_uuid])
  @@index([status])
}

model OutreachSequence {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid())
  user_uuid  String
  name       String
  steps      Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)

  @@index([user_uuid])
}

model FilterJob {
  id           Int       @id @default(autoincrement())
  uuid         String    @unique @default(uuid())
  filter_uuid  String
  status       JobStatus @default(PENDING)
  leads_found  Int       @default(0)
  duration     Int       @default(0)
  error        String?
  started_at   DateTime  @default(now())
  completed_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  filter Filter @relation(fields: [filter_uuid], references: [uuid], onDelete: Cascade)

  @@index([filter_uuid])
  @@index([status])
}

enum AuthRole {
  USER
  ADMIN
  SUPER_ADMIN
  SUPPORT
}

enum SourceType {
  LINKEDIN
  GOOGLE_MAPS
  GOOGLE_SEARCH
  GENERIC_LEAD
  WEBSITE_CRAWLER
  GEMI // greek business directory
  MANUAL
}

enum Channel {
  EMAIL
  SMS
  LINKEDIN
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  ARCHIVED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum MsgStatus {
  PENDING
  SENT
  FAILED
}

enum InteractionType {
  NOTE
  CALL
  EMAIL
}
