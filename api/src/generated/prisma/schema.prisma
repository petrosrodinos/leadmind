// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid())
  email      String   @unique
  phone      String?  @unique
  password   String
  role       AuthRole @default(USER)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  filters             Filter[]
  contacts            Contact[]
  outreach_messages   OutreachMessage[]
  outreach_sequences  OutreachSequence[]
  interactions        Interaction[]
  sender_profiles     SenderProfile[]
  marketing_campaigns MarketingCampaign[]

  @@index([email])
  @@index([phone])
  @@index([uuid])
  @@map("users")
}

model Filter {
  id                    Int                @id @default(autoincrement())
  uuid                  String             @unique @default(uuid())
  user_uuid             String
  name                  String
  source_type           SourceType
  query_config          Json
  enrichment_sources    EnrichmentSource[] @default([])
  enabled               Boolean            @default(true)
  cron_schedule         String?
  channels              Channel[]          @default([EMAIL])
  scoring_instructions  String?
  outreach_instructions String?
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt

  user      User        @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  raw_leads RawLead[]
  contacts  Contact[]
  jobs      FilterJob[]

  @@index([user_uuid])
}

model RawLead {
  id           Int        @id @default(autoincrement())
  uuid         String     @unique @default(uuid())
  filter_uuid  String
  source_type  SourceType
  raw_data     Json
  processed_at DateTime?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  filter Filter @relation(fields: [filter_uuid], references: [uuid], onDelete: Cascade)
  lead   Lead?

  @@index([filter_uuid])
}

// Lead is the generic, public, app-wide record of a person/business.
// It has no owner. Per-user state (status, score, notes) lives on Contact;
// AI-drafted outreach lives on OutreachMessage (one per filter.channel).
// Each Lead is created from a RawLead (`raw_lead_uuid`), which is the audit
// record of what the scraper returned.
model Lead {
  id                 Int        @id @default(autoincrement())
  uuid               String     @unique @default(uuid())
  raw_lead_uuid      String?    @unique
  name               String?
  email              String?
  phone              String?
  company            String?
  website            String?
  linkedin_url       String?
  title              String?
  location           String?
  industry           String?
  description        String?
  source_type        SourceType
  raw_data           Json?
  enrichment_summary String?    @db.Text
  created_at         DateTime   @default(now())
  updated_at         DateTime   @updatedAt

  raw_lead    RawLead?         @relation(fields: [raw_lead_uuid], references: [uuid], onDelete: SetNull)
  contacts    Contact[]
  enrichments LeadEnrichment[]

  @@index([email])
  @@index([linkedin_url])
}

model LeadEnrichment {
  id            Int              @id @default(autoincrement())
  uuid          String           @unique @default(uuid())
  lead_uuid     String
  source        EnrichmentSource
  source_url    String?
  summary       String?          @db.Text
  payload       Json?
  cost_usd      Decimal?         @db.Decimal(12, 6)
  input_tokens  Int?
  output_tokens Int?
  metadata      Json?
  created_at    DateTime         @default(now())

  lead Lead @relation(fields: [lead_uuid], references: [uuid], onDelete: Cascade)

  @@index([lead_uuid])
  @@index([lead_uuid, source])
  @@map("lead_enrichments")
}

model Contact {
  id                  Int        @id @default(autoincrement())
  uuid                String     @unique @default(uuid())
  user_uuid           String
  lead_uuid           String
  filter_uuid         String?
  status              LeadStatus @default(NEW)
  score               Int?
  notes               String?
  name                String?
  email               String?
  phone               String?
  company             String?
  website             String?
  linkedin_url        String?
  title               String?
  location            String?
  industry            String?
  description         String?
  unsubscribed_at     DateTime?
  unsubscribe_token   String?    @unique
  last_interaction_at DateTime?
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  user              User                       @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  lead              Lead                       @relation(fields: [lead_uuid], references: [uuid], onDelete: Cascade)
  filter            Filter?                    @relation(fields: [filter_uuid], references: [uuid], onDelete: SetNull)
  tags              ContactTag[]
  interactions      Interaction[]
  outreach_messages OutreachMessage[]
  campaign_contacts MarketingCampaignContact[]

  @@unique([user_uuid, lead_uuid])
  @@index([user_uuid])
  @@index([status])
  @@index([lead_uuid])
  @@index([email])
  @@index([unsubscribed_at])
  @@index([score])
  @@index([last_interaction_at])
}

model ContactTag {
  id           Int      @id @default(autoincrement())
  contact_uuid String
  tag          String
  created_at   DateTime @default(now())

  contact Contact @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)

  @@unique([contact_uuid, tag])
  @@index([contact_uuid])
}

model Interaction {
  id                    Int             @id @default(autoincrement())
  uuid                  String          @unique @default(uuid())
  contact_uuid          String
  user_uuid             String
  campaign_uuid         String?
  type                  InteractionType
  content               String?
  metadata              Json?
  status_change         Json?
  outreach_message_uuid String?         @unique
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt

  contact          Contact            @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)
  user             User               @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  outreach_message OutreachMessage?   @relation(fields: [outreach_message_uuid], references: [uuid], onDelete: SetNull)
  campaign         MarketingCampaign? @relation(fields: [campaign_uuid], references: [uuid], onDelete: SetNull)

  @@index([contact_uuid])
  @@index([user_uuid])
  @@index([campaign_uuid])
  @@index([type])
  @@index([created_at])
}

model OutreachMessage {
  id                  Int          @id @default(autoincrement())
  uuid                String       @unique @default(uuid())
  user_uuid           String
  contact_uuid        String
  campaign_uuid       String?
  channel             Channel
  direction           MsgDirection @default(OUTBOUND)
  subject             String?
  content             String
  status              MsgStatus    @default(PENDING)
  provider_message_id String?
  idempotency_key     String?      @unique
  scheduled_at        DateTime?
  sent_at             DateTime?
  delivered_at        DateTime?
  opened_at           DateTime?
  clicked_at          DateTime?
  replied_at          DateTime?
  metadata            Json?
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  user        User               @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  contact     Contact            @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)
  campaign    MarketingCampaign? @relation(fields: [campaign_uuid], references: [uuid], onDelete: SetNull)
  interaction Interaction?

  @@index([user_uuid])
  @@index([contact_uuid])
  @@index([status])
  @@index([campaign_uuid])
  @@index([provider_message_id])
  @@index([campaign_uuid, contact_uuid, channel])
}

model OutreachSequence {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid())
  user_uuid  String
  name       String
  steps      Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)

  @@index([user_uuid])
}

model FilterJob {
  id           Int        @id @default(autoincrement())
  uuid         String     @unique @default(uuid())
  filter_uuid  String
  status       JobStatus  @default(PENDING)
  trigger      JobTrigger @default(SCHEDULED)
  leads_found  Int        @default(0)
  duration     Int        @default(0)
  error        String?
  started_at   DateTime   @default(now())
  completed_at DateTime?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  filter Filter @relation(fields: [filter_uuid], references: [uuid], onDelete: Cascade)

  @@index([filter_uuid])
  @@index([status])
}

model SenderProfile {
  id                   Int      @id @default(autoincrement())
  uuid                 String   @unique @default(uuid())
  user_uuid            String
  name                 String
  company_name         String?
  title                String?
  first_name           String?
  last_name            String?
  email                String?
  phone                String?
  website              String?
  address              String?
  city                 String?
  country              String?
  logo_url             String?
  booking_url          String?
  sender_id            String?
  signature            String?  @db.Text
  business_description String?  @db.Text
  is_default           Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  user                User                @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  marketing_campaigns MarketingCampaign[]

  @@index([user_uuid])
  @@map("sender_profiles")
}

model MarketingCampaign {
  id                  Int            @id @default(autoincrement())
  uuid                String         @unique @default(uuid())
  user_uuid           String
  name                String
  description         String?
  status              CampaignStatus @default(DRAFT)
  channels            Channel[]      @default([EMAIL])
  filters_snapshot    Json?
  email_subject       String?
  email_content       String?        @db.Text
  sms_content         String?        @db.Text
  sender_profile_uuid String?
  scheduled_at        DateTime?
  started_at          DateTime?
  completed_at        DateTime?
  cancelled_at        DateTime?

  selected_contact_count Int @default(0)
  total_messages         Int @default(0)
  queued_count           Int @default(0)
  sent_count             Int @default(0)
  failed_count           Int @default(0)
  skipped_count          Int @default(0)
  delivered_count        Int @default(0)
  opened_count           Int @default(0)
  clicked_count          Int @default(0)
  replied_count          Int @default(0)
  bounced_count          Int @default(0)
  unsubscribed_count     Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user              User                       @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  sender_profile    SenderProfile?             @relation(fields: [sender_profile_uuid], references: [uuid], onDelete: SetNull)
  campaign_contacts MarketingCampaignContact[]
  outreach_messages OutreachMessage[]
  interactions      Interaction[]

  @@index([user_uuid])
  @@index([status])
  @@index([scheduled_at])
  @@map("marketing_campaigns")
}

model MarketingCampaignContact {
  id            Int                   @id @default(autoincrement())
  uuid          String                @unique @default(uuid())
  campaign_uuid String
  contact_uuid  String
  channel       Channel
  status        CampaignContactStatus @default(PENDING)
  error_message String?
  sent_at       DateTime?
  delivered_at  DateTime?
  created_at    DateTime              @default(now())
  updated_at    DateTime              @updatedAt

  campaign MarketingCampaign @relation(fields: [campaign_uuid], references: [uuid], onDelete: Cascade)
  contact  Contact           @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)

  @@unique([campaign_uuid, contact_uuid, channel], map: "marketing_campaign_contacts_target_key")
  @@index([campaign_uuid])
  @@index([contact_uuid])
  @@index([status])
  @@index([campaign_uuid, status])
  @@map("marketing_campaign_contacts")
}

enum AuthRole {
  USER
  ADMIN
  SUPER_ADMIN
  SUPPORT
}

enum SourceType {
  LINKEDIN
  GOOGLE_MAPS
  GOOGLE_SEARCH
  GENERIC_LEAD
  WEBSITE_CRAWLER
  GEMI // greek business directory
  MANUAL
}

enum EnrichmentSource {
  LINKEDIN
  WEBSITE
  GOOGLE_SEARCH
  AI
}

enum Channel {
  EMAIL
  SMS
  PHONE_CALL
  LINKEDIN
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  ARCHIVED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum JobTrigger {
  MANUAL
  SCHEDULED
}

enum MsgStatus {
  PENDING
  QUEUED
  SENT
  FAILED
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  UNSUBSCRIBED
  SKIPPED
}

enum MsgDirection {
  OUTBOUND
  INBOUND
}

enum InteractionType {
  NOTE
  CALL
  EMAIL
  MEETING
  STATUS_CHANGE
  CAMPAIGN_EMAIL_SENT
  CAMPAIGN_SMS_SENT
  EMAIL_DELIVERED
  SMS_DELIVERED
  EMAIL_OPENED
  LINK_CLICKED
  REPLY_RECEIVED
  EMAIL_BOUNCED
  EMAIL_FAILED
  SMS_FAILED
  UNSUBSCRIBED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  CANCELLED
  FAILED
}

enum CampaignContactStatus {
  PENDING
  QUEUED
  SENT
  FAILED
  SKIPPED
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  UNSUBSCRIBED
}
