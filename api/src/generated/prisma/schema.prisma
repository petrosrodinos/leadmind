// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid())
  email      String   @unique
  phone      String?  @unique
  password   String
  role       AuthRole @default(USER)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  filters                   Filter[]
  contacts                  Contact[]
  outreach_messages         OutreachMessage[]
  outreach_sequences        OutreachSequence[]
  interactions              Interaction[]
  sender_profiles           SenderProfile[]
  marketing_campaigns       MarketingCampaign[]
  scoring_instructions      ScoringInstruction[]
  openai_batch_jobs         OpenAiBatchJob[]
  integrations              Integration[]
  reminders                 Reminder[]
  forms                     Form[]
  form_completions          FormCompletion[]          @relation("CompletedByUser")
  contact_lists             ContactList[]
  contact_audience_analyses ContactAudienceAnalysis[]

  @@index([email])
  @@index([phone])
  @@index([uuid])
  @@map("users")
}

model Filter {
  id                    Int                @id @default(autoincrement())
  uuid                  String             @unique @default(uuid())
  user_uuid             String
  name                  String
  source_type           SourceType
  query_config          Json
  enrichment_sources    EnrichmentSource[] @default([])
  enabled               Boolean            @default(true)
  cron_schedule         String?
  channels              Channel[]          @default([EMAIL])
  outreach_instructions String?
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt

  user                        User                       @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  raw_leads                   RawLead[]
  contacts                    Contact[]
  jobs                        FilterJob[]
  filter_scoring_instructions FilterScoringInstruction[]
  audience_analyses           ContactAudienceAnalysis[]

  @@index([user_uuid])
}

model ScoringInstruction {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid())
  user_uuid    String
  name         String
  instructions String   @db.Text
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user           User                       @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  filter_links   FilterScoringInstruction[]
  contact_scores ContactScore[]

  @@index([user_uuid])
  @@map("scoring_instructions")
}

model FilterScoringInstruction {
  filter_uuid              String
  scoring_instruction_uuid String
  created_at               DateTime @default(now())

  filter              Filter             @relation(fields: [filter_uuid], references: [uuid], onDelete: Cascade)
  scoring_instruction ScoringInstruction @relation(fields: [scoring_instruction_uuid], references: [uuid], onDelete: Cascade)

  @@id([filter_uuid, scoring_instruction_uuid])
  @@map("filter_scoring_instructions")
}

model RawLead {
  id           Int        @id @default(autoincrement())
  uuid         String     @unique @default(uuid())
  filter_uuid  String
  source_type  SourceType
  raw_data     Json
  processed_at DateTime?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  filter Filter @relation(fields: [filter_uuid], references: [uuid], onDelete: Cascade)
  lead   Lead?

  @@index([filter_uuid])
}

// Lead is the generic, public, app-wide record of a person/business.
// It has no owner. Per-user state (status, notes, per-instruction scores) lives on Contact;
// AI-drafted outreach lives on OutreachMessage (one per filter.channel).
// Each Lead is created from a RawLead (`raw_lead_uuid`), which is the audit
// record of what the scraper returned.
model Lead {
  id                  Int        @id @default(autoincrement())
  uuid                String     @unique @default(uuid())
  raw_lead_uuid       String?    @unique
  name                String?
  email               String?
  phone               String?
  company             String?
  website             String?
  google_maps_url     String?
  linkedin_url        String?
  title               String?
  location            String?
  industry            String?
  description         String?
  source_type         SourceType
  raw_data            Json?
  enrichment_summary  String?    @db.Text
  enrichment_metadata Json?
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  raw_lead    RawLead?         @relation(fields: [raw_lead_uuid], references: [uuid], onDelete: SetNull)
  contacts    Contact[]
  enrichments LeadEnrichment[]

  @@index([email])
  @@index([linkedin_url])
}

model LeadEnrichment {
  id            Int              @id @default(autoincrement())
  uuid          String           @unique @default(uuid())
  lead_uuid     String
  source        EnrichmentSource
  source_url    String?
  summary       String?          @db.Text
  payload       Json?
  cost_usd      Decimal?         @db.Decimal(12, 6)
  input_tokens  Int?
  output_tokens Int?
  metadata      Json?
  created_at    DateTime         @default(now())

  lead Lead @relation(fields: [lead_uuid], references: [uuid], onDelete: Cascade)

  @@index([lead_uuid])
  @@index([lead_uuid, source])
  @@map("lead_enrichments")
}

model Contact {
  id                  Int        @id @default(autoincrement())
  uuid                String     @unique @default(uuid())
  user_uuid           String
  lead_uuid           String
  filter_uuid         String?
  status              LeadStatus @default(NEW)
  notes               String?
  name                String?
  email               String?
  phone               String?
  company             String?
  website             String?
  google_maps_url     String?
  linkedin_url        String?
  title               String?
  location            String?
  industry            String?
  description         String?
  enrichment_summary  String?    @db.Text
  enrichment_metadata Json?
  unsubscribed_at     DateTime?
  unsubscribe_token   String?    @unique
  last_interaction_at DateTime?
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  user              User                       @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  lead              Lead                       @relation(fields: [lead_uuid], references: [uuid], onDelete: Cascade)
  filter            Filter?                    @relation(fields: [filter_uuid], references: [uuid], onDelete: SetNull)
  tags              ContactTag[]
  interactions      Interaction[]
  outreach_messages OutreachMessage[]
  campaign_contacts MarketingCampaignContact[]
  contact_scores    ContactScore[]
  reminders         Reminder[]
  form_completions  FormCompletion[]
  list_memberships  ContactListMember[]
  enrichments       ContactEnrichment[]

  @@unique([user_uuid, lead_uuid])
  @@index([user_uuid])
  @@index([status])
  @@index([lead_uuid])
  @@index([email])
  @@index([unsubscribed_at])
  @@index([last_interaction_at])
}

model ContactEnrichment {
  id            Int              @id @default(autoincrement())
  uuid          String           @unique @default(uuid())
  contact_uuid  String
  source        EnrichmentSource
  source_url    String?
  summary       String?          @db.Text
  payload       Json?
  cost_usd      Decimal?         @db.Decimal(12, 6)
  input_tokens  Int?
  output_tokens Int?
  metadata      Json?
  created_at    DateTime         @default(now())

  contact Contact @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)

  @@index([contact_uuid])
  @@index([contact_uuid, source])
  @@map("contact_enrichments")
}

model ContactScore {
  id                       Int      @id @default(autoincrement())
  contact_uuid             String
  scoring_instruction_uuid String
  score                    Int
  updated_at               DateTime @updatedAt

  contact             Contact            @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)
  scoring_instruction ScoringInstruction @relation(fields: [scoring_instruction_uuid], references: [uuid], onDelete: Cascade)

  @@unique([contact_uuid, scoring_instruction_uuid])
  @@index([contact_uuid])
  @@index([scoring_instruction_uuid])
  @@map("contact_scores")
}

model ContactList {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  user_uuid   String
  title       String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user              User                      @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  members           ContactListMember[]
  audience_analyses ContactAudienceAnalysis[]

  @@index([user_uuid])
  @@map("contact_lists")
}

model ContactListMember {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid())
  list_uuid    String
  contact_uuid String
  created_at   DateTime @default(now())

  list    ContactList @relation(fields: [list_uuid], references: [uuid], onDelete: Cascade)
  contact Contact     @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)

  @@unique([list_uuid, contact_uuid])
  @@index([list_uuid])
  @@index([contact_uuid])
  @@map("contact_list_members")
}

model ContactTag {
  id           Int      @id @default(autoincrement())
  contact_uuid String
  tag          String
  created_at   DateTime @default(now())

  contact Contact @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)

  @@unique([contact_uuid, tag])
  @@index([contact_uuid])
}

model Interaction {
  id                    Int             @id @default(autoincrement())
  uuid                  String          @unique @default(uuid())
  contact_uuid          String
  user_uuid             String
  campaign_uuid         String?
  type                  InteractionType
  content               String?
  metadata              Json?
  status_change         Json?
  outreach_message_uuid String?         @unique
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt

  contact          Contact            @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)
  user             User               @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  outreach_message OutreachMessage?   @relation(fields: [outreach_message_uuid], references: [uuid], onDelete: SetNull)
  campaign         MarketingCampaign? @relation(fields: [campaign_uuid], references: [uuid], onDelete: SetNull)

  @@index([contact_uuid])
  @@index([user_uuid])
  @@index([campaign_uuid])
  @@index([type])
  @@index([created_at])
}

model OutreachMessage {
  id                  Int          @id @default(autoincrement())
  uuid                String       @unique @default(uuid())
  user_uuid           String
  contact_uuid        String
  campaign_uuid       String?
  channel             Channel
  direction           MsgDirection @default(OUTBOUND)
  subject             String?
  content             String
  status              MsgStatus    @default(PENDING)
  provider_message_id String?
  idempotency_key     String?      @unique
  scheduled_at        DateTime?
  sent_at             DateTime?
  delivered_at        DateTime?
  opened_at           DateTime?
  clicked_at          DateTime?
  replied_at          DateTime?
  metadata            Json?
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  user        User               @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  contact     Contact            @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)
  campaign    MarketingCampaign? @relation(fields: [campaign_uuid], references: [uuid], onDelete: SetNull)
  interaction Interaction?

  @@index([user_uuid])
  @@index([contact_uuid])
  @@index([status])
  @@index([campaign_uuid])
  @@index([provider_message_id])
  @@index([campaign_uuid, contact_uuid, channel])
}

model OutreachSequence {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid())
  user_uuid  String
  name       String
  steps      Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)

  @@index([user_uuid])
}

model FilterJob {
  id           Int        @id @default(autoincrement())
  uuid         String     @unique @default(uuid())
  filter_uuid  String
  status       JobStatus  @default(PENDING)
  trigger      JobTrigger @default(SCHEDULED)
  leads_found  Int        @default(0)
  duration     Int        @default(0)
  error        String?
  started_at   DateTime   @default(now())
  completed_at DateTime?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  filter Filter @relation(fields: [filter_uuid], references: [uuid], onDelete: Cascade)

  @@index([filter_uuid])
  @@index([status])
}

model SenderProfile {
  id                   Int      @id @default(autoincrement())
  uuid                 String   @unique @default(uuid())
  user_uuid            String
  name                 String
  company_name         String?
  title                String?
  first_name           String?
  last_name            String?
  email                String?
  phone                String?
  website              String?
  website_utm          Json?
  address              String?
  city                 String?
  country              String?
  logo_url             String?
  booking_url          String?
  booking_utm          Json?
  sender_id            String?
  signature            String?  @db.Text
  business_description String?  @db.Text
  is_default           Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  user                User                @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  marketing_campaigns MarketingCampaign[]

  @@index([user_uuid])
  @@map("sender_profiles")
}

model MarketingCampaign {
  id                  Int            @id @default(autoincrement())
  uuid                String         @unique @default(uuid())
  user_uuid           String
  name                String
  description         String?
  status              CampaignStatus @default(DRAFT)
  campaign_type       CampaignType   @default(STANDARD)
  channels            Channel[]      @default([EMAIL])
  filters_snapshot    Json?
  email_subject       String?
  email_content       String?        @db.Text
  sms_content         String?        @db.Text
  linkedin_content    String?        @db.Text
  ai_prompt           String?        @db.Text
  use_openai_batch    Boolean        @default(false)
  draft_batch_id      String?
  sender_profile_uuid String?
  scheduled_at        DateTime?
  started_at          DateTime?
  completed_at        DateTime?
  cancelled_at        DateTime?

  selected_contact_count Int @default(0)
  total_messages         Int @default(0)
  queued_count           Int @default(0)
  sent_count             Int @default(0)
  failed_count           Int @default(0)
  skipped_count          Int @default(0)
  delivered_count        Int @default(0)
  opened_count           Int @default(0)
  clicked_count          Int @default(0)
  replied_count          Int @default(0)
  website_visit_count    Int @default(0)
  booking_visit_count    Int @default(0)
  bounced_count          Int @default(0)
  unsubscribed_count     Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user              User                       @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  sender_profile    SenderProfile?             @relation(fields: [sender_profile_uuid], references: [uuid], onDelete: SetNull)
  campaign_contacts MarketingCampaignContact[]
  outreach_messages OutreachMessage[]
  interactions      Interaction[]

  @@index([user_uuid])
  @@index([status])
  @@index([scheduled_at])
  @@map("marketing_campaigns")
}

model MarketingCampaignContact {
  id            Int                   @id @default(autoincrement())
  uuid          String                @unique @default(uuid())
  campaign_uuid String
  contact_uuid  String
  channel       Channel
  status        CampaignContactStatus @default(PENDING)
  error_message String?
  sent_at       DateTime?
  delivered_at  DateTime?
  created_at    DateTime              @default(now())
  updated_at    DateTime              @updatedAt

  campaign MarketingCampaign @relation(fields: [campaign_uuid], references: [uuid], onDelete: Cascade)
  contact  Contact           @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)

  @@unique([campaign_uuid, contact_uuid, channel], map: "marketing_campaign_contacts_target_key")
  @@index([campaign_uuid])
  @@index([contact_uuid])
  @@index([status])
  @@index([campaign_uuid, status])
  @@map("marketing_campaign_contacts")
}

enum AuthRole {
  USER
  ADMIN
  SUPER_ADMIN
  SUPPORT
}

enum SourceType {
  LINKEDIN
  GOOGLE_MAPS
  GOOGLE_SEARCH
  GENERIC_LEAD
  WEBSITE_CRAWLER
  GEMI // greek business directory
  MANUAL
}

enum EnrichmentSource {
  LINKEDIN
  WEBSITE
  GOOGLE_SEARCH
  AI
  GEMI
}

enum Channel {
  EMAIL
  SMS
  PHONE_CALL
  LINKEDIN
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NURTURING
  CONVERTED
  LOST
  ARCHIVED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum JobTrigger {
  MANUAL
  SCHEDULED
}

enum MsgStatus {
  PENDING
  QUEUED
  SENT
  FAILED
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  UNSUBSCRIBED
  SKIPPED
}

enum MsgDirection {
  OUTBOUND
  INBOUND
}

enum InteractionType {
  NOTE
  CALL
  EMAIL
  SMS
  MEETING
  STATUS_CHANGE
  CAMPAIGN_EMAIL_SENT
  CAMPAIGN_SMS_SENT
  EMAIL_DELIVERED
  SMS_DELIVERED
  EMAIL_OPENED
  LINK_CLICKED
  WEBSITE_VISIT
  BOOKING_VISIT
  REPLY_RECEIVED
  EMAIL_BOUNCED
  EMAIL_FAILED
  SMS_FAILED
  UNSUBSCRIBED
}

enum CampaignType {
  STANDARD
  PERSONALIZED
}

enum CampaignStatus {
  DRAFT
  DRAFTS_READY
  SCHEDULED
  SENDING
  COMPLETED
  CANCELLED
  FAILED
}

enum CampaignContactStatus {
  PENDING
  QUEUED
  SENT
  FAILED
  SKIPPED
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  UNSUBSCRIBED
}

model OpenAiBatchJob {
  id                 String             @id @default(uuid())
  batch_id           String             @unique
  user_uuid          String
  type               OpenAiBatchJobType
  status             OpenAiBatchStatus  @default(IN_PROGRESS)
  total_requests     Int                @default(0)
  completed_requests Int                @default(0)
  failed_requests    Int                @default(0)
  input_file_id      String?
  output_file_id     String?
  error_file_id      String?
  expires_at         DateTime?
  finished_at        DateTime?
  context            Json?
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  user               User               @relation(fields: [user_uuid], references: [uuid])

  @@map("openai_batch_jobs")
}

enum OpenAiBatchJobType {
  CONTACT_SCORE
  LEAD_ENRICH
  MESSAGE_CREATE
}

enum OpenAiBatchStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
  EXPIRED
  CANCELLED
}

enum ExternalIntegrationProvider {
  OPENAI
  ANTHROPIC
  RESEND
  TWILIO
  APIFY
  HUBSPOT
}

enum IntegrationKeyType {
  API_KEY
  WEBHOOK_SECRET
  ACCOUNT_SID
  AUTH_TOKEN
  ACCESS_TOKEN
}

model Integration {
  id         Int                         @id @default(autoincrement())
  uuid       String                      @unique @default(uuid())
  user_uuid  String
  provider   ExternalIntegrationProvider
  title      String
  created_at DateTime                    @default(now())
  updated_at DateTime                    @updatedAt

  user User             @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  keys IntegrationKey[]

  @@unique([user_uuid, provider])
  @@index([user_uuid])
  @@index([provider])
  @@map("integrations")
}

model IntegrationKey {
  id               Int                @id @default(autoincrement())
  uuid             String             @unique @default(uuid())
  integration_uuid String
  key_type         IntegrationKeyType
  account          String             @default("1")
  secret           String             @db.Text
  last4            String?
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt

  integration Integration @relation(fields: [integration_uuid], references: [uuid], onDelete: Cascade)

  @@unique([integration_uuid, key_type, account])
  @@index([integration_uuid])
  @@map("integration_keys")
}

enum ReminderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Reminder {
  id           Int            @id @default(autoincrement())
  uuid         String         @unique @default(uuid())
  user_uuid    String
  contact_uuid String
  title        String?
  notes        String?        @db.Text
  remind_at    DateTime
  status       ReminderStatus @default(PENDING)
  job_id       String?        @unique

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user    User    @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  contact Contact @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)

  @@index([user_uuid])
  @@index([contact_uuid])
  @@index([remind_at])
  @@index([status])
  @@index([user_uuid, status])
  @@index([user_uuid, remind_at])
  @@map("reminders")
}

enum FieldType {
  TEXT_INPUT
  TEXTAREA
  NUMBER_INPUT
  EMAIL_INPUT
  PHONE_INPUT
  DATE_INPUT
  CHECKBOX
  RADIO_GROUP
  DROPDOWN
  MULTI_SELECT_DROPDOWN
  LABEL
  SECTION_HEADER
}

model Form {
  id          Int     @id @default(autoincrement())
  uuid        String  @unique @default(uuid())
  user_uuid   String
  name        String
  description String? @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user        User             @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  fields      FormField[]
  completions FormCompletion[]

  @@index([user_uuid])
  @@map("forms")
}

model FormField {
  id            Int       @id @default(autoincrement())
  uuid          String    @unique @default(uuid())
  form_uuid     String
  label         String
  field_type    FieldType
  placeholder   String?
  help_text     String?
  required      Boolean   @default(false)
  default_value String?
  options       Json?
  order_index   Int       @default(0)
  enabled       Boolean   @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  form              Form                  @relation(fields: [form_uuid], references: [uuid], onDelete: Cascade)
  completion_values FormCompletionValue[]

  @@index([form_uuid])
  @@index([form_uuid, order_index])
  @@map("form_fields")
}

model FormCompletion {
  id                Int    @id @default(autoincrement())
  uuid              String @unique @default(uuid())
  form_uuid         String
  contact_uuid      String
  completed_by_uuid String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  form         Form                  @relation(fields: [form_uuid], references: [uuid], onDelete: Cascade)
  contact      Contact               @relation(fields: [contact_uuid], references: [uuid], onDelete: Cascade)
  completed_by User                  @relation("CompletedByUser", fields: [completed_by_uuid], references: [uuid], onDelete: Cascade)
  values       FormCompletionValue[]

  @@index([form_uuid])
  @@index([contact_uuid])
  @@map("form_completions")
}

model FormCompletionValue {
  id              Int    @id @default(autoincrement())
  uuid            String @unique @default(uuid())
  completion_uuid String
  field_uuid      String
  value           String @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  completion FormCompletion @relation(fields: [completion_uuid], references: [uuid], onDelete: Cascade)
  field      FormField      @relation(fields: [field_uuid], references: [uuid], onDelete: Cascade)

  @@index([completion_uuid])
  @@index([field_uuid])
  @@map("form_completion_values")
}

enum ContactAudienceAnalysisScope {
  FILTER
  LIST
}

enum ContactAudienceAnalysisStatus {
  PENDING
  COMPLETED
  FAILED
}

model ContactAudienceAnalysis {
  id                Int                           @id @default(autoincrement())
  uuid              String                        @unique @default(uuid())
  user_uuid         String
  scope             ContactAudienceAnalysisScope
  filter_uuid       String?
  contact_list_uuid String?
  audience_name     String
  stats_snapshot    Json
  analysis          Json                          @default("{}")
  status            ContactAudienceAnalysisStatus @default(PENDING)
  error             String?
  provider          String?
  model             String?
  input_tokens      Int?
  output_tokens     Int?
  cost_usd          Float?
  created_at        DateTime                      @default(now())
  updated_at        DateTime                      @updatedAt

  user        User         @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  filter      Filter?      @relation(fields: [filter_uuid], references: [uuid], onDelete: Cascade)
  contactList ContactList? @relation(fields: [contact_list_uuid], references: [uuid], onDelete: Cascade)

  @@index([user_uuid])
  @@index([filter_uuid])
  @@index([contact_list_uuid])
  @@index([scope])
  @@map("contact_audience_analyses")
}
