{
  "openapi": "3.0.1",
  "info": {
    "title": "LinkedIn Profile Scraper",
    "description": "Scrapes LinkedIn profile data from URLs, extracting comprehensive person information including experience, education, posts, and more.",
    "version": "1.0",
    "x-build-id": "seqviCjDwTGOXZw5w"
  },
  "servers": [
    {
      "url": "https://api.apify.com/v2"
    }
