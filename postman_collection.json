{
  "info": {
    "name": "Leadfinder API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] },
            "description": "Returns a hello message to confirm the API is running."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/email/register", "host": ["{{baseUrl}}"], "path": ["auth", "email", "register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"John Doe\"\n}"
            },
            "description": "Register a new user with email and password."
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/email/login", "host": ["{{baseUrl}}"], "path": ["auth", "email", "login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Login with email and password. Copy the returned token into the {{token}} variable."
          }
        },
        {
          "name": "Waitlist",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/email/waitlist", "host": ["{{baseUrl}}"], "path": ["auth", "email", "waitlist"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"ref_code\": \"ABC123\"\n}"
            },
            "description": "Add a user to the waitlist with a referral code."
          }
        }
      ]
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "List leads",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/leads?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["leads"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "source_type", "value": "", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Paginated list of public leads. Filter by source_type or search by name/email/company."
          }
        },
        {
          "name": "Get lead by UUID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/leads/:uuid", "host": ["{{baseUrl}}"], "path": ["leads", ":uuid"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Get a single public lead by UUID."
          }
        },
        {
          "name": "Get lead enrichments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/leads/:uuid/enrichments?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["leads", ":uuid", "enrichments"],
              "variable": [{ "key": "uuid", "value": "" }],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "source", "value": "", "disabled": true },
                { "key": "search", "value": "", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Paginated enrichment history for a lead, newest first."
          }
        },
        {
          "name": "Update lead (admin)",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/leads/:uuid", "host": ["{{baseUrl}}"], "path": ["leads", ":uuid"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"company\": \"Acme Corp\",\n  \"title\": \"CEO\",\n  \"email\": \"jane@acme.com\"\n}"
            },
            "description": "Update a lead. Requires ADMIN or SUPER_ADMIN role."
          }
        },
        {
          "name": "Delete lead (admin)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/leads/:uuid", "host": ["{{baseUrl}}"], "path": ["leads", ":uuid"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Delete a lead. Requires ADMIN or SUPER_ADMIN role."
          }
        },
        {
          "name": "Enrich lead",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/leads/:uuid/enrich", "host": ["{{baseUrl}}"], "path": ["leads", ":uuid", "enrich"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sources\": [\"LINKEDIN\", \"WEBSITE\"]\n}"
            },
            "description": "Enqueue AI enrichment for a lead."
          }
        }
      ]
    },
    {
      "name": "Search (Elasticsearch)",
      "item": [
        {
          "name": "Search leads (semantic)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/search/leads?q=software engineer&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["search", "leads"],
              "query": [
                { "key": "q", "value": "software engineer" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "source_type", "value": "", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Semantic KNN search over public leads using Elasticsearch embeddings."
          }
        },
        {
          "name": "Search contacts (semantic)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/search/contacts?q=founder fintech&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["search", "contacts"],
              "query": [
                { "key": "q", "value": "founder fintech" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "", "disabled": true },
                { "key": "min_score", "value": "", "disabled": true },
                { "key": "tags", "value": "", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Semantic KNN search over the current user's contacts."
          }
        }
      ]
    },
    {
      "name": "Contacts",
      "item": [
        {
          "name": "Create contact",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/contacts", "host": ["{{baseUrl}}"], "path": ["contacts"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"company\": \"Acme\",\n  \"title\": \"CTO\"\n}"
            },
            "description": "Create a contact manually — also creates a MANUAL Lead behind the scenes."
          }
        },
        {
          "name": "List contacts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/contacts?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["contacts"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "", "disabled": true },
                { "key": "search", "value": "", "disabled": true },
                { "key": "tags", "value": "", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "List contacts for the current user."
          }
        },
        {
          "name": "Convert lead to contact",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/contacts/from-lead/:lead_uuid", "host": ["{{baseUrl}}"], "path": ["contacts", "from-lead", ":lead_uuid"], "variable": [{ "key": "lead_uuid", "value": "" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Adopt a public Lead as a Contact for the current user."
          }
        },
        {
          "name": "Get contact",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/contacts/:uuid", "host": ["{{baseUrl}}"], "path": ["contacts", ":uuid"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Get a contact with tags, interactions, lead, and outreach messages."
          }
        },
        {
          "name": "Update contact",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/contacts/:uuid", "host": ["{{baseUrl}}"], "path": ["contacts", ":uuid"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"title\": \"VP Engineering\",\n  \"notes\": \"Met at conference\"\n}"
            },
            "description": "Update contact profile fields and notes."
          }
        },
        {
          "name": "Delete contact",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/contacts/:uuid", "host": ["{{baseUrl}}"], "path": ["contacts", ":uuid"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Delete a contact."
          }
        },
        {
          "name": "Update contact status",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/contacts/:uuid/status", "host": ["{{baseUrl}}"], "path": ["contacts", ":uuid", "status"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONTACTED\"\n}"
            },
            "description": "Update contact status — also records an Interaction."
          }
        },
        {
          "name": "Update contact tags",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/contacts/:uuid/tags", "host": ["{{baseUrl}}"], "path": ["contacts", ":uuid", "tags"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tags\": [\"vip\", \"warm-lead\"]\n}"
            },
            "description": "Replace the full tag set for a contact."
          }
        },
        {
          "name": "Add note",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/contacts/:uuid/notes", "host": ["{{baseUrl}}"], "path": ["contacts", ":uuid", "notes"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Interested in enterprise plan\"\n}"
            },
            "description": "Add a note — creates an Interaction of type NOTE."
          }
        },
        {
          "name": "Log call",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/contacts/:uuid/calls", "host": ["{{baseUrl}}"], "path": ["contacts", ":uuid", "calls"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"duration_minutes\": 15,\n  \"notes\": \"Discussed pricing\"\n}"
            },
            "description": "Log a call — creates an Interaction of type CALL."
          }
        },
        {
          "name": "Log meeting",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/contacts/:uuid/meetings", "host": ["{{baseUrl}}"], "path": ["contacts", ":uuid", "meetings"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scheduled_at\": \"2026-06-01T10:00:00Z\",\n  \"notes\": \"Product demo\"\n}"
            },
            "description": "Log a meeting — creates an Interaction of type MEETING."
          }
        },
        {
          "name": "Get interactions",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/contacts/:uuid/interactions", "host": ["{{baseUrl}}"], "path": ["contacts", ":uuid", "interactions"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "List all interactions for a contact, most recent first."
          }
        },
        {
          "name": "Trigger AI scoring",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/contacts/:uuid/score", "host": ["{{baseUrl}}"], "path": ["contacts", ":uuid", "score"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Trigger AI scoring for the contact."
          }
        },
        {
          "name": "Trigger draft messages",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/contacts/:uuid/draft-messages", "host": ["{{baseUrl}}"], "path": ["contacts", ":uuid", "draft-messages"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Trigger AI to (re)draft OutreachMessage rows per filter channel."
          }
        },
        {
          "name": "AI draft message (one-off)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/contacts/ai-draft-message", "host": ["{{baseUrl}}"], "path": ["contacts", "ai-draft-message"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contact_uuid\": \"\",\n  \"channel\": \"EMAIL\",\n  \"prompt\": \"Write a short intro email focusing on our AI features\"\n}"
            },
            "description": "Generate a one-off AI draft (Email or SMS) without persisting it."
          }
        },
        {
          "name": "Enrich contact",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/contacts/:uuid/enrich", "host": ["{{baseUrl}}"], "path": ["contacts", ":uuid", "enrich"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sources\": [\"LINKEDIN\"]\n}"
            },
            "description": "Queue enrichment for the contact's lead."
          }
        },
        {
          "name": "List contact messages",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/contacts/:uuid/messages", "host": ["{{baseUrl}}"], "path": ["contacts", ":uuid", "messages"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "List the contact's outreach messages (drafts + sent)."
          }
        }
      ]
    },
    {
      "name": "Filters",
      "item": [
        {
          "name": "Create filter",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/filters", "host": ["{{baseUrl}}"], "path": ["filters"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"SaaS Founders NYC\",\n  \"industry\": \"SaaS\",\n  \"location\": \"New York\"\n}"
            },
            "description": "Create a new lead filter for the current user."
          }
        },
        {
          "name": "List filters",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/filters", "host": ["{{baseUrl}}"], "path": ["filters"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "List all filters for the current user."
          }
        },
        {
          "name": "Get filter",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/filters/:uuid", "host": ["{{baseUrl}}"], "path": ["filters", ":uuid"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Get a filter by UUID."
          }
        },
        {
          "name": "Update filter",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/filters/:uuid", "host": ["{{baseUrl}}"], "path": ["filters", ":uuid"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Filter Name\"\n}"
            },
            "description": "Update a filter."
          }
        },
        {
          "name": "Delete filter",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/filters/:uuid", "host": ["{{baseUrl}}"], "path": ["filters", ":uuid"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Delete a filter."
          }
        },
        {
          "name": "Run filter manually",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/filters/:uuid/run", "host": ["{{baseUrl}}"], "path": ["filters", ":uuid", "run"], "variable": [{ "key": "uuid", "value": "" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Manually enqueue a scrape job for a filter."
          }
        },
        {
          "name": "List filter jobs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/filters/:uuid/jobs?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["filters", ":uuid", "jobs"],
              "variable": [{ "key": "uuid", "value": "" }],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "List FilterJob records for a filter, paginated."
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get stats",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/dashboard/stats", "host": ["{{baseUrl}}"], "path": ["dashboard", "stats"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Aggregated counters: totals, conversion rate, status breakdown."
          }
        },
        {
          "name": "Get top contacts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/dashboard/top-contacts?limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["dashboard", "top-contacts"],
              "query": [{ "key": "limit", "value": "5" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Top scored contacts for the dashboard widget."
          }
        },
        {
          "name": "Get pending drafts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/dashboard/pending-drafts?limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["dashboard", "pending-drafts"],
              "query": [{ "key": "limit", "value": "5" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Contacts that have at least one PENDING outreach message."
          }
        }
      ]
    },
    {
      "name": "Outreach",
      "item": [
        {
          "name": "List messages",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/outreach/messages?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["outreach", "messages"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "contact_uuid", "value": "", "disabled": true },
                { "key": "status", "value": "", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "List outreach messages for the current user."
          }
        },
        {
          "name": "Create and queue message",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/outreach/messages", "host": ["{{baseUrl}}"], "path": ["outreach", "messages"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contact_uuid\": \"\",\n  \"channel\": \"EMAIL\",\n  \"subject\": \"Quick intro\",\n  \"content\": \"Hi, I wanted to reach out...\"\n}"
            },
            "description": "Create and immediately enqueue an outreach message."
          }
        },
        {
          "name": "Create draft message",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/outreach/messages/draft", "host": ["{{baseUrl}}"], "path": ["outreach", "messages", "draft"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
